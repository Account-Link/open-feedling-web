# OpenFeedling deploy with OpenVPN sidecar — env template.
# Copy this to deploy/.env (gitignored) and fill in your values.

# === OpenFeedling required ===
EXT_SHARED_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# === OpenVPN sidecar required ===
# 1. Download a .ovpn from your VPN provider (ProtonVPN, Mullvad, AirVPN, ...)
# 2. Encode it: base64 -w0 your-config.ovpn
# 3. Paste the single-line result below.
OVPN_CONFIG_BASE64=

# Most providers require user/pass auth.
OPENVPN_USER=
OPENVPN_PASS=

# === Optional ===
OPENROUTER_API_KEY=
DIARY_MODEL=anthropic/claude-sonnet-4-5
PORT=3000
