# Web Push (required) — generate with: deno task gen-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Shared secret (required) — extension uses this to authenticate cookie uploads
# Generate with: openssl rand -hex 32
EXT_SHARED_SECRET=

# Cat diary (optional) — leave blank to disable
OPENROUTER_API_KEY=
DIARY_MODEL=anthropic/claude-sonnet-4-5

# Runtime
PORT=3000
DATA_DIR=./data
POLL_IDLE_MS=300000
POLL_ACTIVE_MS=60000
